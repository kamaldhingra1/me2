---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import config from "@/config";
import { useTranslations } from "@/i18n";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
} = Astro.props;

const t = useTranslations(Astro.currentLocale);

// Check if there's a valid modification date that occurs after publish date
const isModified = modDatetime && new Date(modDatetime) > new Date(pubDatetime);

const tz = postTimezone ?? config.site.timezone;

const pubDateObj = dayjs(pubDatetime).tz(tz);
const modDateObj = isModified ? dayjs(modDatetime).tz(tz) : null;

const formattedPubDate = pubDateObj.format("D MMM, YYYY");
const formattedModDate = modDateObj ? modDateObj.format("D MMM, YYYY") : null;
---

<div class:list={["text-muted-foreground flex flex-col gap-y-1 sm:flex-row sm:gap-x-4", className]}>
  <div class="flex items-center gap-x-2">
    <IconCalendar
      class:list={[
        "inline-block size-6 min-w-5.5",
        { "scale-90": size === "sm" },
      ]}
    />
    <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
      {t.post.publishedAt || "Published"}:
    </span>
    <time
      class:list={["text-sm font-medium", { "sm:text-base": size === "lg" }]}
      datetime={pubDateObj.toISOString()}
    >
      {formattedPubDate}
    </time>
  </div>

  {
    isModified && modDateObj && (
      <div class="flex items-center gap-x-2">
        <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
          {t.post.updatedAt || "Updated"}:
        </span>
        <time
          class:list={["text-sm font-medium", { "sm:text-base": size === "lg" }]}
          datetime={modDateObj.toISOString()}
        >
          {formattedModDate}
        </time>
      </div>
    )
  }
</div>